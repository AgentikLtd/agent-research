# agent-research template — required + optional environment variables.
# Production values live in SOPS-encrypted secrets; this file is the canonical
# contract for what `loadEnv()` reads. Keep it in sync with `src/env.ts`.

# --- required ---
AGENT_ID=agent_replace_me
AGENT_NAME=research-genesys
TENANT_ID=tenant_replace_me
HUB_BASE_URL=http://localhost:3000
HUB_AGENT_TOKEN=replace_me

# --- optional (have defaults) ---
PORT=4003
LOG_LEVEL=info

# --- optional (no default) ---
# OTLP collector for spans; if unset, tracing is initialised with no exporter
# (spans recorded in-process but never flushed). Hub's default is :4318.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Sandbox-check probe bypass for local dev; "1" skips the boot-time check.
# SANDBOX_CHECK_SKIP=0
